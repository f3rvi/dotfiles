#!/bin/sh

op=$( echo -e "’Ćæ Poweroff\n’ā£ Reboot\n’åå Suspend\n’ĆŻ Lock\n’éŗ Logout" | wofi -i --dmenu | awk '{print tolower($2)}' )

case $op in 
        poweroff)
                ;&
        reboot)
                ;&
        suspend)
                systemctl $op
                ;;
        lock)
		swaylock
                ;;
        logout)
                swaymsg exit
                ;;
esac
